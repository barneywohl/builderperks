BUILDERPERKS_ADMIN_KEY=replace-with-long-random-admin-key
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_from_stripe_webhook

# Optional fallback if using Stripe Payment Links instead of dynamic Checkout Sessions.
BUILDERPERKS_CHECKOUT_URL_STARTER=https://buy.stripe.com/...
BUILDERPERKS_CHECKOUT_URL_LAUNCH=https://buy.stripe.com/...
BUILDERPERKS_CHECKOUT_URL_TAKEOVER=https://buy.stripe.com/...

# Optional provider credential readiness gates. Credentials alone do not make a
# provider serve-ready; also set BUILDERPERKS_PROVIDER_APPROVED_<PROVIDER_KEY>=1
# only after the provider has approved BuilderPerks inventory.
# Example: BUILDERPERKS_PROVIDER_APPROVED_ETHICALADS=1
# Optional comma-separated approved third-party JSON offer feeds. Every feed is
# treated as approved_partner demand only after you intentionally configure it.
# Feed items should include company/advertiser, headline/title, body/description,
# url/clickUrl, and optional cta/audience/targetTools/categories.
